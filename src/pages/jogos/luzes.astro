---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Confetti from '@/components/ui/Confetti.astro';
import ScoreBoard from '@/components/ui/ScoreBoard.astro';
import Countdown from '@/components/ui/Countdown.astro';
import CelebrationOverlay from '@/components/ui/CelebrationOverlay.astro';
import TimerBar from '@/components/ui/TimerBar.astro';
import LightButton from '@/components/games/LightButton.astro';
import GameCharacter from '@/components/games/GameCharacter.astro';
import config from '@/config/memory-lights.json';
import type { MemoryLightsConfig } from '@/games/memory-lights/types';

const gameConfig = config as MemoryLightsConfig;
const lights = gameConfig.lights;
---

<BaseLayout fullscreen={true}>
  <div
    x-data="memoryLights"
    x-init="init()"
    class="relative h-full w-full overflow-hidden flex flex-col"
    @ml:light-on.window="activeLightIndex = $event.detail.index"
    @ml:light-off.window="activeLightIndex = null"
    @ml:state-change.window="score = $event.detail.score; stars = $event.detail.stars; round = $event.detail.round; gameState = $event.detail.gameState"
    @ml:correct.window="
      centerPoints = $event.detail.earned;
      startFlyAnimation();
      $dispatch('celebration', { text: 'Muito bem! 🎉' });
      message = '';
      bgFlash = 'bg-green-400/20';
      setTimeout(() => bgFlash = '', 600);
    "
    @ml:wrong.window="message = 'Tente de novo! 💪'; messageType = 'error'; bgFlash = 'bg-red-400/20'; setTimeout(() => { message = ''; messageType = ''; bgFlash = ''; }, 1500)"
    @ml:countdown.window="countdownNumber = $event.detail.number"
    @ml:light-tap.window="engine.handleTap($event.detail.index)"
    @ml:btn-color.window="bgAmbient = $event.detail.color; setTimeout(() => bgAmbient = '', 400)"
    @ml:pause-toggle.window="togglePause()"
  >
    <Confetti />

    <!-- Ambient background glow -->
    <div
      class="fixed inset-0 z-0 pointer-events-none transition-colors duration-500 ease-out"
      :style="'background: ' + (bgAmbient || 'transparent')"
      style="opacity: 0.15;"
    ></div>

    <!-- Background tint flash -->
    <div
      x-show="bgFlash"
      x-transition:enter="transition duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition duration-500"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-10 pointer-events-none transition-colors duration-300"
      :class="bgFlash"
    ></div>

    <!-- Flying points animation -->
    <div
      x-show="showFlyPoints"
      x-transition:enter="transition duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="hidden"
      class="fixed z-40 pointer-events-none"
      :style="flyStyle"
    >
      <span class="text-5xl font-black text-yellow-400 drop-shadow-[0_0_25px_rgba(251,191,36,0.9)]" x-text="'+' + centerPoints"></span>
    </div>

    <div class="relative z-20" id="scoreboard-wrapper">
      <ScoreBoard />
    </div>

    <!-- Bottom stars bar -->
    <div
      class="fixed left-0 right-0 z-30 pointer-events-none flex justify-center"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + clamp(40px, 10vw, 72px));"
      x-show="!showStartButton && !showTimeout"
      x-cloak
    >
      <div class="flex items-center gap-1 bg-white/85 backdrop-blur rounded-full px-4 py-1.5 border-2 border-purple-200 shadow-md">
        <template x-for="i in 5" :key="i">
          <span
            class="text-xl transition-all duration-500"
            :class="i <= stars ? 'scale-110' : 'opacity-25 scale-75'"
            :style="i <= stars ? 'animation: star-spin 0.5s ease-out' : ''"
          >⭐</span>
        </template>
      </div>
    </div>

    <div class="flex-1 flex items-center justify-center" id="game-area" x-show="!showStartButton" x-cloak>
      <div class="grid grid-cols-2 gap-[min(6vw,32px)] place-items-center p-4">
        {
          lights.map((light, i) => (
            <LightButton
              index={i}
              color={light.color}
              glow={light.glow}
              emoji={light.emoji}
              label={light.label}
            />
          ))
        }
      </div>
    </div>

    <div
      class="character-stage fixed z-[60] pointer-events-none select-none"
      x-show="!showStartButton && !isPaused && !showTimeout"
      x-cloak
    >
      <GameCharacter />
    </div>

    <div
      x-show="message"
      x-transition
      class="absolute bottom-28 left-0 right-0 z-50 flex justify-center pointer-events-none"
    >
      <div
        class="backdrop-blur-xl rounded-2xl px-6 py-3 shadow-xl border-2 transition-colors duration-300"
        :class="messageType === 'error'
          ? 'bg-red-100/90 border-red-400'
          : 'bg-green-100/90 border-green-400'"
      >
        <p
          class="text-2xl font-extrabold text-center animate-bounce"
          :class="messageType === 'error' ? 'text-red-600' : 'text-green-600'"
          x-text="message"
        ></p>
      </div>
    </div>

    <Countdown />
    <CelebrationOverlay />
    <TimerBar />

    <!-- Pause menu overlay -->
    <div
      x-show="isPaused"
      x-transition:enter="transition duration-300 ease-out"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition duration-200 ease-in"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-md"
    >
      <!-- Close X -->
      <button
        @click="resumeGame()"
        class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/90 backdrop-blur shadow-lg border-2 border-purple-200 flex items-center justify-center text-2xl text-purple-600 hover:scale-110 transition-all z-10"
        aria-label="Fechar"
      >
        ✕
      </button>

      <!-- Menu items -->
      <div
        x-show="isPaused"
        x-transition:enter="transition duration-400 ease-out delay-100"
        x-transition:enter-start="opacity-0 translate-y-8 scale-90"
        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
        class="flex flex-col items-center gap-6"
      >
        <button
          @click="resumeGame()"
          class="flex items-center gap-4 bg-white/90 backdrop-blur rounded-3xl px-8 py-5 shadow-xl border-2 border-green-300 hover:scale-105 hover:border-green-400 hover:shadow-2xl transition-all duration-300 w-64"
        >
          <span class="text-4xl">▶️</span>
          <span class="text-xl font-extrabold text-green-600">Continuar</span>
        </button>

        <a
          href="/"
          class="flex items-center gap-4 bg-white/90 backdrop-blur rounded-3xl px-8 py-5 shadow-xl border-2 border-red-300 hover:scale-105 hover:border-red-400 hover:shadow-2xl transition-all duration-300 w-64"
        >
          <span class="text-4xl">🚪</span>
          <span class="text-xl font-extrabold text-red-500">Sair do jogo</span>
        </a>
      </div>
    </div>

    <!-- Timeout restart overlay -->
    <div
      x-show="showTimeout"
      x-transition
      class="absolute inset-0 z-50 flex items-center justify-center"
    >
      <div
        x-show="showTimeout"
        x-transition:enter="transition duration-500"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        class="absolute inset-0 bg-red-500/20 backdrop-blur-sm"
      ></div>
      <div class="relative z-10 text-center">
        <p class="text-7xl mb-4 drop-shadow-lg" style="animation: shake 0.5s ease-in-out">⏰</p>
        <button
          @click="restartGame()"
          class="btn btn-lg btn-primary rounded-full px-10 py-6 text-2xl font-black shadow-2xl animate-bounce border-4 border-red-400"
        >
          🔄 Tentar de novo!
        </button>
      </div>
    </div>

    <div
      x-show="showStartButton"
      x-transition
      class="absolute inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm"
    >
      <button
        @click="startGame()"
        class="btn btn-lg btn-primary rounded-full px-10 py-6 text-2xl font-black shadow-2xl animate-bounce border-4 border-yellow-300"
      >
        🎮 Começar!
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  import Alpine from 'alpinejs';
  import { MemoryLightsEngine } from '@/games/memory-lights/engine';
  import gameConfig from '@/config/memory-lights.json';
  import type { MemoryLightsConfig } from '@/games/memory-lights/types';
  import { playScoreTick } from '@/lib/audio';

  Alpine.data('scoreBoard', () => ({
    localScore: 0,
    localStars: 1,
    displayScore: 0,
    earnedText: 0,
    showFlyBadge: false,
    scorePulse: false,

    init() {
      window.addEventListener('ml:score-animate', ((e: CustomEvent) => {
        setTimeout(() => {
          this.animateScore(this.localScore, e.detail.total, e.detail.earned);
        }, 800);
      }) as EventListener);

      window.addEventListener('ml:state-change', ((e: CustomEvent) => {
        this.localStars = e.detail.stars;
        if (this.displayScore === 0 && e.detail.score > 0) {
          this.displayScore = e.detail.score;
          this.localScore = e.detail.score;
        }
      }) as EventListener);
    },

    animateScore(from: number, to: number, earned: number) {
      this.scorePulse = true;
      setTimeout(() => { this.scorePulse = false; }, 800);
      this.earnedText = earned;
      this.showFlyBadge = true;
      setTimeout(() => { this.showFlyBadge = false; }, 800);

      const steps = 15;
      const increment = (to - from) / steps;
      let current = from;
      let step = 0;

      const tick = () => {
        step++;
        current += increment;
        if (step >= steps) {
          this.displayScore = to;
          this.localScore = to;
          return;
        }
        this.displayScore = Math.round(current);
        requestAnimationFrame(tick);
      };

      const soundTicks = Math.min(Math.ceil(earned / 5), 8);
      for (let i = 0; i < soundTicks; i++) {
        setTimeout(() => {
          playScoreTick();
        }, i * 50 + 800);
      }

      requestAnimationFrame(tick);
    },
  }));

  Alpine.data('timerBar', () => ({
    enabled: true,
    show: false,
    percent: 100,
    barColor: '#22c55e',

    init() {
      window.addEventListener('ml:timer-start', ((e: CustomEvent) => {
        this.show = true;
        this.percent = 100;
        this.barColor = '#22c55e';
      }) as EventListener);

      window.addEventListener('ml:timer-stop', (() => {
        this.show = false;
      }) as EventListener);

      window.addEventListener('ml:timer-tick', ((e: CustomEvent) => {
        this.percent = e.detail.percent;
        const p = e.detail.percent;
        if (p > 60) this.barColor = '#22c55e';
        else if (p > 30) this.barColor = '#eab308';
        else this.barColor = '#ef4444';
      }) as EventListener);
    },
  }));

  Alpine.data('memoryLights', () => ({
    engine: null as MemoryLightsEngine | null,
    score: 0,
    stars: 1,
    round: 1,
    message: '',
    messageType: '',
    bgFlash: '',
    bgAmbient: '',
    showFlyPoints: false,
    centerPoints: 0,
    flyStyle: '',
    gameState: 'IDLE' as string,
    activeLightIndex: null as number | null,
    showCountdown: false,
    showStartButton: true,
    showTimeout: false,
    isPaused: false,

    init() {
      const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
      this.engine = new MemoryLightsEngine(gameConfig as MemoryLightsConfig, canvas);

      window.addEventListener('ml:play-score-tick', () => {
        playScoreTick();
      });

      window.addEventListener('ml:timer-expired', () => {
        this.showTimeout = true;
      });

      const setMood = (mood: string, duration = 0) => {
        window.dispatchEvent(new CustomEvent('character:set-mood', { detail: { mood, duration } }));
      };

      window.addEventListener('ml:correct', () => setMood('happy', 1800));
      window.addEventListener('ml:wrong', () => setMood('sad', 1800));
      window.addEventListener('ml:timer-expired', () => setMood('tired', 2500));
      window.addEventListener('ml:state-change', ((e: CustomEvent) => {
        const gs = e.detail?.gameState;
        if (gs === 'SHOWING_SEQUENCE') setMood('thinking');
        else if (gs === 'WAITING_INPUT') setMood('idle');
        else if (gs === 'CELEBRATING') setMood('excited', 1500);
      }) as EventListener);
    },

    startGame() {
      this.showStartButton = false;
      this.showTimeout = false;
      this.isPaused = false;
      if (this.engine) {
        this.engine.start();
      }
    },

    togglePause() {
      if (!this.engine || this.showStartButton) return;
      if (this.isPaused) {
        this.resumeGame();
      } else {
        this.isPaused = true;
        this.engine.pause();
      }
    },

    resumeGame() {
      this.isPaused = false;
      this.engine?.resume();
    },

    restartGame() {
      this.showTimeout = false;
      this.isPaused = false;
      this.engine?.destroy();
      const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
      this.engine = new MemoryLightsEngine(gameConfig as MemoryLightsConfig, canvas);
      this.engine.start();
    },

    startFlyAnimation() {
      const scoreBox = document.getElementById('score-box');
      if (!scoreBox) return;
      const target = scoreBox.getBoundingClientRect();
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight * 0.35;
      const endX = target.left + target.width / 2 - 25;
      const endY = target.top + target.height / 2 - 18;

      this.flyStyle = `left: ${cx - 30}px; top: ${cy}px; transform: scale(2); transition: none;`;
      this.showFlyPoints = true;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          this.flyStyle = `left: ${endX}px; top: ${endY}px; transform: scale(0.6); transition: left 0.8s cubic-bezier(0.25, 0.1, 0.15, 1), top 0.6s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.8s ease-out;`;
        });
      });

      setTimeout(() => {
        this.showFlyPoints = false;
      }, 900);
    },

    destroy() {
      if (this.engine) {
        this.engine.destroy();
      }
    },
  }));

  Alpine.start();
</script>

<style is:global>
  [x-cloak] { display: none !important; }

  .character-stage {
    width: clamp(110px, 30vw, 180px);
    right: clamp(8px, 3vw, 24px);
    bottom: calc(env(safe-area-inset-bottom, 0px) + clamp(40px, 10vw, 72px));
    line-height: 0;
    animation: character-float 4s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.18));
  }
  .character-stage > div { display: block; width: 100%; }
  .character-stage svg { width: 100%; height: auto; display: block; }

  @keyframes character-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>
