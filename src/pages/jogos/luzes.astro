---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Confetti from '@/components/ui/Confetti.astro';
import ScoreBoard from '@/components/ui/ScoreBoard.astro';
import Countdown from '@/components/ui/Countdown.astro';
import CelebrationOverlay from '@/components/ui/CelebrationOverlay.astro';
import LightButton from '@/components/games/LightButton.astro';
import config from '@/config/memory-lights.json';
import type { MemoryLightsConfig } from '@/games/memory-lights/types';

const gameConfig = config as MemoryLightsConfig;
const lights = gameConfig.lights;
---

<BaseLayout>
  <div
    x-data="memoryLights"
    x-init="init()"
    class="relative min-h-dvh w-full overflow-hidden flex flex-col"
    @ml:light-on.window="activeLightIndex = $event.detail.index"
    @ml:light-off.window="activeLightIndex = null"
    @ml:state-change.window="score = $event.detail.score; stars = $event.detail.stars; round = $event.detail.round; gameState = $event.detail.gameState"
    @ml:correct.window="
      centerPoints = $event.detail.earned;
      startFlyAnimation();
      $dispatch('celebration', { text: 'Muito bem! 🎉' });
      message = '';
      bgFlash = 'bg-green-400/20';
      setTimeout(() => bgFlash = '', 600);
    "
    @ml:wrong.window="message = 'Tente de novo! 💪'; messageType = 'error'; bgFlash = 'bg-red-400/20'; setTimeout(() => { message = ''; messageType = ''; bgFlash = ''; }, 1500)"
    @ml:countdown.window="countdownNumber = $event.detail.number"
    @ml:light-tap.window="engine.handleTap($event.detail.index)"
  >
    <Confetti />

    <!-- Background tint flash -->
    <div
      x-show="bgFlash"
      x-transition:enter="transition duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition duration-500"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-10 pointer-events-none transition-colors duration-300"
      :class="bgFlash"
    ></div>

    <!-- Flying points animation -->
    <div
      x-show="showFlyPoints"
      x-transition:enter="transition duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="hidden"
      class="fixed z-40 pointer-events-none"
      :style="flyStyle"
    >
      <span class="text-5xl font-black text-yellow-400 drop-shadow-[0_0_25px_rgba(251,191,36,0.9)]" x-text="'+' + centerPoints"></span>
    </div>

    <div class="relative z-20" id="scoreboard-wrapper">
      <ScoreBoard />
    </div>

    <div class="flex-1 flex items-center justify-center" id="game-area" x-show="!showStartButton" x-cloak>
      <div class="grid grid-cols-2 gap-[min(6vw,32px)] place-items-center p-4">
        {
          lights.map((light, i) => (
            <LightButton
              index={i}
              color={light.color}
              glow={light.glow}
              emoji={light.emoji}
              label={light.label}
            />
          ))
        }
      </div>
    </div>

    <div
      x-show="message"
      x-transition
      class="absolute bottom-28 left-0 right-0 z-50 flex justify-center pointer-events-none"
    >
      <div
        class="backdrop-blur-xl rounded-2xl px-6 py-3 shadow-xl border-2 transition-colors duration-300"
        :class="messageType === 'error'
          ? 'bg-red-100/90 border-red-400'
          : 'bg-green-100/90 border-green-400'"
      >
        <p
          class="text-2xl font-extrabold text-center animate-bounce"
          :class="messageType === 'error' ? 'text-red-600' : 'text-green-600'"
          x-text="message"
        ></p>
      </div>
    </div>

    <Countdown />
    <CelebrationOverlay />

    <div
      x-show="showStartButton"
      x-transition
      class="absolute inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm"
    >
      <button
        @click="startGame()"
        class="btn btn-lg btn-primary rounded-full px-10 py-6 text-2xl font-black shadow-2xl animate-bounce border-4 border-yellow-300"
      >
        🎮 Começar!
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  import Alpine from 'alpinejs';
  import { MemoryLightsEngine } from '@/games/memory-lights/engine';
  import gameConfig from '@/config/memory-lights.json';
  import type { MemoryLightsConfig } from '@/games/memory-lights/types';
  import { playScoreTick } from '@/lib/audio';

  Alpine.data('scoreBoard', () => ({
    localScore: 0,
    localStars: 1,
    displayScore: 0,
    earnedText: 0,
    showFlyBadge: false,
    scorePulse: false,

    init() {
      window.addEventListener('ml:score-animate', ((e: CustomEvent) => {
        setTimeout(() => {
          this.animateScore(this.localScore, e.detail.total, e.detail.earned);
        }, 800);
      }) as EventListener);

      window.addEventListener('ml:state-change', ((e: CustomEvent) => {
        this.localStars = e.detail.stars;
        if (this.displayScore === 0 && e.detail.score > 0) {
          this.displayScore = e.detail.score;
          this.localScore = e.detail.score;
        }
      }) as EventListener);
    },

    animateScore(from: number, to: number, earned: number) {
      this.scorePulse = true;
      setTimeout(() => { this.scorePulse = false; }, 800);
      this.earnedText = earned;
      this.showFlyBadge = true;
      setTimeout(() => { this.showFlyBadge = false; }, 800);

      const steps = 15;
      const increment = (to - from) / steps;
      let current = from;
      let step = 0;

      const tick = () => {
        step++;
        current += increment;
        if (step >= steps) {
          this.displayScore = to;
          this.localScore = to;
          return;
        }
        this.displayScore = Math.round(current);
        requestAnimationFrame(tick);
      };

      const soundTicks = Math.min(Math.ceil(earned / 5), 8);
      for (let i = 0; i < soundTicks; i++) {
        setTimeout(() => {
          playScoreTick();
        }, i * 50 + 800);
      }

      requestAnimationFrame(tick);
    },
  }));

  Alpine.data('memoryLights', () => ({
    engine: null as MemoryLightsEngine | null,
    score: 0,
    stars: 1,
    round: 1,
    message: '',
    messageType: '',
    bgFlash: '',
    showFlyPoints: false,
    centerPoints: 0,
    flyStyle: '',
    gameState: 'IDLE' as string,
    activeLightIndex: null as number | null,
    showCountdown: false,
    showStartButton: true,

    init() {
      const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
      this.engine = new MemoryLightsEngine(gameConfig as MemoryLightsConfig, canvas);

      window.addEventListener('ml:play-score-tick', () => {
        playScoreTick();
      });
    },

    startGame() {
      this.showStartButton = false;
      if (this.engine) {
        this.engine.start();
      }
    },

    startFlyAnimation() {
      const scoreBox = document.getElementById('score-box');
      if (!scoreBox) return;
      const target = scoreBox.getBoundingClientRect();
      const cx = window.innerWidth / 2;
      const cy = window.innerHeight * 0.35;
      const endX = target.left + target.width / 2 - 25;
      const endY = target.top + target.height / 2 - 18;

      this.flyStyle = `left: ${cx - 30}px; top: ${cy}px; transform: scale(2); transition: none;`;
      this.showFlyPoints = true;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          this.flyStyle = `left: ${endX}px; top: ${endY}px; transform: scale(0.6); transition: left 0.8s cubic-bezier(0.25, 0.1, 0.15, 1), top 0.6s cubic-bezier(0.25, 0.1, 0.25, 1), transform 0.8s ease-out;`;
        });
      });

      setTimeout(() => {
        this.showFlyPoints = false;
      }, 900);
    },

    destroy() {
      if (this.engine) {
        this.engine.destroy();
      }
    },
  }));

  Alpine.start();
</script>

<style is:global>
  [x-cloak] { display: none !important; }
</style>
