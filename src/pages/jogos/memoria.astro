---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Confetti from '@/components/ui/Confetti.astro';
import GameCharacter from '@/components/games/GameCharacter.astro';
import config from '@/config/memory-cards.json';
import type { MemoryCardsConfig } from '@/games/memory-cards/types';

const gameConfig = config as MemoryCardsConfig;
const cardBack = gameConfig.theme.cardBack;
const showLabels = gameConfig.behavior.showLabels;
---

<BaseLayout fullscreen={true}>
  <div
    x-data="memoryCards"
    x-init="init()"
    class="relative h-full w-full overflow-hidden flex flex-col"
    @mc:state-change.window="
      score = $event.detail.score;
      stars = $event.detail.stars;
      round = $event.detail.round;
      streak = $event.detail.streak;
      gameState = $event.detail.gameState;
    "
  >
    <Confetti />

    <!-- Background flash -->
    <div
      x-show="bgFlash"
      x-transition:enter="transition duration-200"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition duration-400"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-10 pointer-events-none"
      :class="bgFlash"
    ></div>

    <!-- Top bar -->
    <div class="relative z-20 flex items-center justify-between px-4 py-3 w-full">
      <button
        @click="togglePause()"
        class="btn btn-ghost btn-sm btn-circle text-2xl"
        aria-label="Menu"
      >☰</button>
      <div class="flex items-center gap-3">
        <div class="rounded-full px-4 py-2 bg-white/85 border-2 border-purple-200 shadow flex items-center gap-1">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-gradient-to-br from-yellow-300 to-yellow-500 border-2 border-yellow-600 text-yellow-900 text-[10px] font-black">$</span>
          <span class="font-extrabold text-lg text-purple-700 tabular-nums" x-text="score"></span>
        </div>
        <div class="rounded-full px-3 py-1.5 bg-white/85 border-2 border-purple-200 shadow text-xs font-extrabold text-purple-600">
          <span x-text="'Rodada ' + round"></span>
        </div>
      </div>
    </div>

    <!-- Bottom stars bar -->
    <div
      class="fixed left-0 right-0 z-30 pointer-events-none flex justify-center"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + clamp(40px, 10vw, 72px));"
    >
      <div class="flex items-center gap-1 bg-white/85 backdrop-blur rounded-full px-4 py-1.5 border-2 border-purple-200 shadow-md">
        <template x-for="i in 5" :key="i">
          <span
            class="text-xl transition-all duration-500"
            :class="i <= stars ? 'scale-110' : 'opacity-25 scale-75'"
          >⭐</span>
        </template>
      </div>
    </div>

    <!-- Cards grid -->
    <div
      class="flex-1 min-h-0 flex items-center justify-center px-3"
      style="padding-bottom: calc(env(safe-area-inset-bottom, 0px) + clamp(110px, 24vw, 170px));"
    >
      <div
        class="grid gap-2 sm:gap-3"
        :style="`width: 100%; max-width: min(100%, 480px); max-height: 100%; aspect-ratio: ${columns} / ${Math.max(1, Math.ceil(cards.length / columns))}; grid-template-columns: repeat(${columns}, minmax(0, 1fr)); grid-auto-rows: 1fr;`"
      >
        <template x-for="(card, index) in cards" :key="card.uid">
          <div
            class="card-fly-wrap w-full h-full"
            :class="collecting ? 'is-collecting' : (dealing ? 'is-dealing' : '')"
            :style="`--anim-delay: ${(collecting ? cards.length - 1 - index : index) * 35}ms;`"
          >
            <button
              @click="onCardTap(card)"
              class="memory-card-3d relative w-full h-full outline-none transition-transform duration-200"
              :class="card.matched ? 'cursor-default' : 'cursor-pointer hover:scale-[1.03]'"
              :disabled="card.matched"
              :aria-label="card.image.label"
            >
              <div
                class="memory-card-inner"
                :class="{ 'is-flipped': card.open || card.matched }"
              >
                <div
                  class="memory-card-face memory-card-back rounded-2xl border-[3px] border-white/80 shadow-lg overflow-hidden"
                  :style="`background-image: url('${cardBack}'); background-size: cover; background-position: center;`"
                ></div>
                <div
                  class="memory-card-face memory-card-front rounded-2xl overflow-hidden border-[3px]"
                  :class="card.matched
                    ? 'border-yellow-300 shadow-[0_0_20px_rgba(252,211,77,0.7)]'
                    : 'border-white/80 shadow-lg'"
                >
                  <img
                    :src="card.image.src"
                    :alt="card.image.label"
                    class="w-full h-full object-cover bg-white"
                    loading="eager"
                    decoding="async"
                  />
                  {showLabels && (
                    <span
                      class="absolute bottom-1 left-1 right-1 text-center text-xs font-extrabold text-purple-800 bg-white/80 rounded px-1 py-0.5 truncate"
                      x-text="card.image.label"
                    ></span>
                  )}
                </div>
              </div>
            </button>
          </div>
        </template>
      </div>
    </div>

    <!-- Message banner -->
    <div
      x-show="message"
      x-transition
      class="absolute bottom-28 left-0 right-0 z-50 flex justify-center pointer-events-none"
    >
      <div
        class="backdrop-blur-xl rounded-2xl px-6 py-3 shadow-xl border-2"
        :class="messageType === 'err'
          ? 'bg-red-100/90 border-red-400'
          : 'bg-green-100/90 border-green-400'"
      >
        <p
          class="text-2xl font-extrabold text-center"
          :class="messageType === 'err' ? 'text-red-600' : 'text-green-600'"
          x-text="message"
        ></p>
      </div>
    </div>

    <!-- Character -->
    <div
      class="character-stage fixed z-[60] pointer-events-none select-none"
      x-show="!isPaused && !showWin"
      x-cloak
    >
      <GameCharacter />
    </div>

    <!-- Win overlay -->
    <div
      x-show="showWin"
      x-transition:enter="transition duration-500"
      x-transition:enter-start="opacity-0 scale-75"
      x-transition:enter-end="opacity-100 scale-100"
      class="fixed inset-0 z-50 flex items-center justify-center pointer-events-none"
    >
      <div class="bg-yellow-100/95 backdrop-blur rounded-3xl px-10 py-6 shadow-2xl border-4 border-yellow-400 text-center">
        <p class="text-7xl mb-2 animate-bounce">🎉</p>
        <p class="text-3xl font-black text-yellow-700">Ganhou!</p>
        <p class="text-base font-extrabold text-yellow-600 mt-1">Próxima rodada chegando…</p>
      </div>
    </div>

    <!-- Pause menu -->
    <div
      x-show="isPaused"
      x-transition
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-md"
    >
      <button
        @click="resumeGame()"
        class="absolute w-12 h-12 rounded-full bg-white/90 shadow-lg border-2 border-purple-200 flex items-center justify-center text-2xl text-purple-600"
        style="top: calc(env(safe-area-inset-top, 0px) + 1rem); right: calc(env(safe-area-inset-right, 0px) + 1rem);"
        aria-label="Fechar"
      >✕</button>
      <div class="flex flex-col items-center gap-6">
        <button
          @click="resumeGame()"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-green-300 w-64"
        >
          <span class="text-4xl">▶️</span>
          <span class="text-xl font-extrabold text-green-600">Continuar</span>
        </button>
        <button
          @click="resetHistory()"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-orange-300 w-64"
        >
          <span class="text-4xl">🔄</span>
          <span class="text-xl font-extrabold text-orange-500">Resetar histórico</span>
        </button>
        <a
          href="/"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-red-300 w-64"
        >
          <span class="text-4xl">🚪</span>
          <span class="text-xl font-extrabold text-red-500">Sair do jogo</span>
        </a>
      </div>
    </div>

  </div>
</BaseLayout>

<script>
  import Alpine from 'alpinejs';
  import { MemoryCardsEngine } from '@/games/memory-cards/engine';
  import { initAudio, startBackgroundMusic } from '@/lib/audio';
  import gameConfig from '@/config/memory-cards.json';
  import type { MemoryCardsConfig, CardData } from '@/games/memory-cards/types';

  const config = gameConfig as MemoryCardsConfig;

  (async () => {
    try {
      const pending = sessionStorage.getItem('pendingBgMusic');
      if (!pending) return;
      sessionStorage.removeItem('pendingBgMusic');
      const { url, volume } = JSON.parse(pending) as { url: string; volume: number };
      await initAudio();
      await startBackgroundMusic(url, volume);
    } catch {}
  })();

  Alpine.data('memoryCards', () => ({
    engine: null as MemoryCardsEngine | null,
    cards: [] as CardData[],
    columns: 3,
    score: 0,
    stars: 1,
    round: 1,
    streak: 0,
    gameState: 'IDLE' as string,
    message: '',
    messageType: '',
    bgFlash: '',
    showWin: false,
    isPaused: false,
    dealing: false,
    collecting: false,
    cardBack: config.theme.cardBack,

    init() {
      const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
      this.engine = new MemoryCardsEngine(config, canvas);

      window.addEventListener('mc:round-start', ((e: CustomEvent) => {
        this.columns = e.detail.columns;
        this.collecting = false;
        this.dealing = true;
        this.cards = (e.detail.cards as CardData[]).map((c) => ({ ...c }));
        this.message = '';
        const settle = 700 + e.detail.cards.length * 35;
        setTimeout(() => { this.dealing = false; }, settle);
      }) as EventListener);

      window.addEventListener('mc:card-open', ((e: CustomEvent) => {
        const card = this.cards.find((c) => c.uid === e.detail.uid);
        if (card) card.open = true;
      }) as EventListener);

      window.addEventListener('mc:card-close', ((e: CustomEvent) => {
        const uids = e.detail.uids as string[];
        uids.forEach((uid) => {
          const card = this.cards.find((c) => c.uid === uid);
          if (card) card.open = false;
        });
      }) as EventListener);

      window.addEventListener('mc:card-match', ((e: CustomEvent) => {
        [e.detail.uidA, e.detail.uidB].forEach((uid: string) => {
          const card = this.cards.find((c) => c.uid === uid);
          if (card) { card.open = true; card.matched = true; }
        });
        this.message = 'Par! 🎉';
        this.messageType = 'ok';
        this.bgFlash = 'bg-green-400/20';
        setTimeout(() => { this.bgFlash = ''; }, 500);
        setTimeout(() => { this.message = ''; }, 1200);
      }) as EventListener);

      window.addEventListener('mc:card-mismatch', () => {
        this.message = 'Tente outra vez!';
        this.messageType = 'err';
        this.bgFlash = 'bg-red-400/15';
        setTimeout(() => { this.bgFlash = ''; this.message = ''; }, 1100);
      });

      window.addEventListener('mc:win', () => {
        this.showWin = true;
        setTimeout(() => { this.collecting = true; }, 2800);
        setTimeout(() => { this.showWin = false; }, 4200);
      });

      const setMood = (mood: string, duration = 0) => {
        window.dispatchEvent(new CustomEvent('character:set-mood', { detail: { mood, duration } }));
      };
      window.addEventListener('mc:card-match', () => setMood('happy', 1500));
      window.addEventListener('mc:card-mismatch', () => setMood('sad', 1200));
      window.addEventListener('mc:win', () => setMood('excited', 3500));
      window.addEventListener('mc:round-start', () => setMood('excited', 1200));

      this.engine.start();
    },

    onCardTap(card: CardData) {
      if (card.matched || card.open) return;
      this.engine?.handleTap(card.uid);
    },

    togglePause() {
      if (!this.engine) return;
      if (this.isPaused) this.resumeGame();
      else { this.isPaused = true; this.engine.pause(); }
    },

    resumeGame() {
      this.isPaused = false;
      this.engine?.resume();
    },

    resetHistory() {
      if (!confirm('Tem certeza que quer apagar a pontuação e começar do zero?')) return;
      this.engine?.resetHistory();
      this.isPaused = false;
      this.showWin = false;
      this.message = '';
    },
  }));

  Alpine.start();
</script>

<style is:global>
  [x-cloak] { display: none !important; }

  .character-stage {
    width: clamp(110px, 28vw, 170px);
    right: clamp(8px, 3vw, 24px);
    bottom: calc(env(safe-area-inset-bottom, 0px) + clamp(40px, 10vw, 72px));
    line-height: 0;
    animation: character-float 4s ease-in-out infinite;
    filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.18));
  }
  .character-stage > div { display: block; width: 100%; }
  .character-stage svg { width: 100%; height: auto; display: block; }

  @keyframes character-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ─── Memory card 3D flip ─────────────────────── */
  .memory-card-3d {
    perspective: 1000px;
    background: transparent;
    border: 0;
    padding: 0;
  }
  .memory-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0.1, 0.3, 1);
  }
  .memory-card-inner.is-flipped {
    transform: rotateY(180deg);
  }
  .memory-card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .memory-card-front {
    transform: rotateY(180deg);
  }

  /* ─── Card deal / collect animations ─────────────── */
  .card-fly-wrap {
    transform-origin: center;
    will-change: transform, opacity;
  }
  .card-fly-wrap.is-dealing {
    animation: card-deal 0.6s cubic-bezier(0.2, 0.85, 0.3, 1.05) backwards;
    animation-delay: var(--anim-delay, 0ms);
  }
  .card-fly-wrap.is-collecting {
    animation: card-collect 0.45s cubic-bezier(0.55, 0.05, 0.7, 0.25) forwards;
    animation-delay: var(--anim-delay, 0ms);
  }
  @keyframes card-deal {
    0% {
      transform: translate(55vw, 60vh) rotate(-22deg) scale(0.22);
      opacity: 0;
    }
    55% { opacity: 1; }
    100% {
      transform: translate(0, 0) rotate(0deg) scale(1);
      opacity: 1;
    }
  }
  @keyframes card-collect {
    0% {
      transform: translate(0, 0) rotate(0deg) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(55vw, 60vh) rotate(15deg) scale(0.22);
      opacity: 0;
    }
  }
</style>
