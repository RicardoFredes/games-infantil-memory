---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { games } from '@/games/registry';

const enabled = games.filter((g) => g.enabled);
---

<BaseLayout>
  <div class="h-full w-full flex flex-col items-center px-4 pt-6 pb-10 overflow-y-auto">
    <header class="mb-6 text-center">
      <h1 class="text-3xl text-purple-700 drop-shadow-sm tracking-wide">
        Vamos Brincar!
      </h1>
    </header>

    <div class="w-full max-w-md grid grid-cols-2 gap-5">
      {
        enabled.map((game) => (
          <a
            href={game.route}
            data-game-launch
            data-bg-music={game.backgroundMusic}
            data-bg-volume={String(game.backgroundVolume ?? -16)}
            class="game-card group flex flex-col items-center
                   active:scale-95 hover:scale-[1.04] transition-transform duration-200"
            aria-label={game.title}
          >
            <div
              class="relative w-full aspect-square overflow-hidden rounded-[2rem] shadow-xl border-[6px] border-white"
              style={`background: linear-gradient(135deg, ${game.color}33, ${game.color}66)`}
            >
              {game.image ? (
                <img
                  src={game.image}
                  alt={game.title}
                  loading="eager"
                  class="absolute inset-0 w-full h-full object-cover"
                  onerror="this.replaceWith(Object.assign(document.createElement('span'),{textContent:this.dataset.fallback,className:'absolute inset-0 flex items-center justify-center',style:'font-size:6.5rem;line-height:1'}))"
                  data-fallback={game.icon}
                />
              ) : (
                <span class="absolute inset-0 flex items-center justify-center" style="font-size:6.5rem;line-height:1">{game.icon}</span>
              )}
            </div>

            <h3
              class="mt-3 text-base text-purple-800 text-center tracking-wide leading-tight"
              style="text-shadow: 0 2px 0 rgba(255,255,255,0.6)"
            >{game.title}</h3>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script>
  import { initAudio, startBackgroundMusic } from '@/lib/audio';

  document.querySelectorAll<HTMLAnchorElement>('a[data-game-launch]').forEach((link) => {
    link.addEventListener('click', async (e) => {
      const url = link.dataset.bgMusic;
      const volume = Number(link.dataset.bgVolume ?? -16);
      if (!url) return;
      e.preventDefault();
      try {
        sessionStorage.setItem('pendingBgMusic', JSON.stringify({ url, volume }));
      } catch {}
      try {
        await initAudio();
        await startBackgroundMusic(url, volume);
      } catch {}
      window.location.href = link.href;
    });
  });
</script>

<style>
  .game-card {
    animation: card-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
  }
  .game-card:nth-child(1) { animation-delay: 0.05s; }
  .game-card:nth-child(2) { animation-delay: 0.15s; }
  .game-card:nth-child(3) { animation-delay: 0.25s; }
  .game-card:nth-child(4) { animation-delay: 0.35s; }

  @keyframes card-pop {
    0%   { opacity: 0; transform: scale(0.5) translateY(20px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>
