---
import BaseLayout from '@/layouts/BaseLayout.astro';
import gamesConfig from '@/config/games.json';

const enabled = gamesConfig.games.filter(g => g.enabled);
const categories = [...new Set(enabled.map(g => g.category))];
---

<BaseLayout>
  <div class="min-h-dvh flex flex-col items-center px-4 py-8">
    <header class="text-center mb-8">
      <p class="text-purple-400 font-bold text-sm tracking-wide uppercase mb-1">Jogos Educativos</p>
      <h1 class="text-4xl font-black text-purple-700 drop-shadow-sm">
        Central de Jogos
      </h1>
      <p class="text-purple-500/70 font-semibold mt-1">Escolha um jogo e divirta-se aprendendo!</p>
    </header>

    <div class="w-full max-w-md space-y-8">
      {
        categories.map(category => (
          <section>
            <div class="flex items-center gap-2 mb-3">
              <span class="w-2 h-2 rounded-full bg-purple-400"></span>
              <h2 class="text-sm font-extrabold text-purple-500 uppercase tracking-widest">{category}</h2>
            </div>
            <div class="space-y-3">
              {
                enabled.filter(g => g.category === category).map(game => (
                  <a
                    href={game.route}
                    class="group block relative overflow-hidden bg-white/80 backdrop-blur rounded-3xl p-5 shadow-md border-2 border-white/60
                           hover:scale-[1.02] hover:shadow-xl hover:border-purple-200 transition-all duration-300"
                  >
                    <div class="flex items-center gap-4">
                      <div
                        class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl shadow-sm flex-shrink-0"
                        style={`background: linear-gradient(135deg, ${game.color}18, ${game.color}33)`}
                      >
                        {game.icon}
                      </div>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-lg font-extrabold text-purple-800 truncate">{game.name}</h3>
                        <p class="text-xs text-purple-500/70 mt-0.5 line-clamp-2">{game.description}</p>
                        <div class="flex items-center gap-2 mt-2">
                          <span class="badge badge-xs badge-outline border-purple-300 text-purple-500">
                            {game.ageRange[0]}-{game.ageRange[1]} anos
                          </span>
                          <span class="badge badge-xs badge-ghost text-purple-400">{game.difficulty}</span>
                        </div>
                      </div>
                      <div class="text-2xl text-purple-300 group-hover:text-purple-500 group-hover:translate-x-1 transition-all flex-shrink-0">
                        ▶
                      </div>
                    </div>
                  </a>
                ))
              }
            </div>
          </section>
        ))
      }
    </div>

    <footer class="mt-10 text-center text-purple-300/50 text-xs">
      <p>Em breve: novos jogos e categorias!</p>
    </footer>
  </div>
</BaseLayout>
