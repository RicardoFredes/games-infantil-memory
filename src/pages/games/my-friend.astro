---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GameCharacter from '@/components/games/GameCharacter.astro';
import OptionsBar from '@/games/my-friend/components/OptionsBar.astro';
import HitZones from '@/games/my-friend/components/HitZones.astro';
import config from '@/games/my-friend/config.json';
import type { MyFriendConfig } from '@/games/my-friend/types';

const cfg = config as MyFriendConfig;
---

<BaseLayout>
  <div
    x-data="myFriend"
    x-init="init()"
    class="relative h-full w-full overflow-hidden flex flex-col"
  >
    <div class="relative z-20 flex items-center justify-between px-4 py-3 w-full">
      <button
        @click="togglePause()"
        class="btn btn-ghost btn-sm btn-circle text-2xl"
        aria-label="Menu"
      >☰</button>
      <h1 class="text-lg text-purple-700">Meu Amigo</h1>
      <span class="w-8"></span>
    </div>

    <div
      class="flex-1 min-h-0 relative pointer-events-auto select-none"
      id="my-friend-stage"
    >
      <div class="floor"></div>
      <div class="character-stage">
        <div class="character-shadow"></div>
        <GameCharacter palette={cfg.defaultPalette} />
        <HitZones />
      </div>
      <div class="touch-fx" aria-hidden="true"></div>
    </div>

    <OptionsBar />

    <!-- Pause menu -->
    <div
      x-show="isPaused"
      x-transition
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-md"
    >
      <button
        @click="resumeGame()"
        class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/90 shadow-lg border-2 border-purple-200 flex items-center justify-center text-2xl text-purple-600"
        aria-label="Fechar"
      >✕</button>
      <div class="flex flex-col items-center gap-6">
        <button
          @click="resumeGame()"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-green-300 w-64"
        >
          <span class="text-4xl">▶️</span>
          <span class="text-xl text-green-600">Continuar</span>
        </button>
        <a
          href="/"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-red-300 w-64"
        >
          <span class="text-4xl">🚪</span>
          <span class="text-xl text-red-500">Sair do jogo</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import Alpine from 'alpinejs';
  import { createPresentation } from '@/games/my-friend/presentation';

  Alpine.data('myFriend', createPresentation);
  Alpine.start();
</script>

<style is:global>
  [x-cloak] { display: none !important; }

  #my-friend-stage {
    overflow: hidden;
  }

  #my-friend-stage .floor {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 50%;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(0,0,0,0.08) 0%, transparent 60%),
      linear-gradient(to bottom, #8FCB60 0%, #4F8A38 100%);
    border-top: 4px solid #B7E48A;
    z-index: 1;
    opacity: 0.5;
  }

  #my-friend-stage .character-stage {
    position: absolute;
    left: 50%;
    bottom: 25%;
    transform: translateX(-50%);
    width: clamp(440px, 95vw, 720px);
    line-height: 0;
    z-index: 3;
  }
  #my-friend-stage .character-stage > .character-container { display: block; width: 100%; }
  #my-friend-stage .character-stage svg.character-svg { width: 100%; height: auto; display: block; }

  #my-friend-stage .touch-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 6;
  }
  #my-friend-stage .touch-ripple {
    position: absolute;
    width: 90px;
    height: 90px;
    margin-left: -45px;
    margin-top: -45px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(255, 220, 255, 0.55) 45%,
      rgba(180, 140, 255, 0.0) 80%
    );
    pointer-events: none;
    animation: my-friend-ripple 600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    will-change: transform, opacity;
  }
  @keyframes my-friend-ripple {
    0%   { transform: scale(0.2); opacity: 0.95; }
    60%  { opacity: 0.6; }
    100% { transform: scale(2.4); opacity: 0; }
  }

  /* ===== Activity layer ===== */
  #my-friend-stage .mf-activity-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 7;
  }

  #my-friend-stage .mf-apple {
    position: absolute;
    width: clamp(54px, 9vw, 78px);
    height: clamp(54px, 9vw, 78px);
    transform: translate(-50%, 100%);
    will-change: transform, opacity;
    filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.18));
  }
  #my-friend-stage .mf-apple svg { width: 100%; height: 100%; display: block; }

  #my-friend-stage .mf-crumb {
    position: absolute;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    margin-top: -4px;
    border-radius: 50%;
    background: #C36B2D;
    animation: mf-crumb-fall 700ms ease-in forwards;
  }
  @keyframes mf-crumb-fall {
    0%   { transform: translate(0, 0) scale(1);   opacity: 1; }
    100% { transform: translate(var(--dx, 0), 80px) scale(0.6); opacity: 0; }
  }

  /* ===== Dance ===== */
  #my-friend-stage .mf-music-note {
    position: absolute;
    font-size: clamp(28px, 5vw, 38px);
    font-weight: 600;
    pointer-events: none;
    will-change: transform, opacity;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.18);
    animation: mf-music-rise 2200ms ease-out forwards;
  }
  @keyframes mf-music-rise {
    0%   { transform: translate(-50%, 0)                       rotate(0)         scale(0.6); opacity: 0; }
    15%  { transform: translate(calc(-50% + var(--drift, 0)), -10%) rotate(var(--rot, 0)) scale(1);   opacity: 1; }
    100% { transform: translate(calc(-50% + var(--drift, 0)), -180px) rotate(var(--rot, 0)) scale(0.85); opacity: 0; }
  }

  #my-friend-stage .character-shadow {
    position: absolute;
    left: 50%;
    bottom: 5%;
    transform: translateX(-50%);
    width: 50%;
    height: clamp(10px, 2vw, 20px);
    border-radius: 50%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.2));
    filter: blur(4px);
    pointer-events: none;
    z-index: -1;
    opacity: 0.5;
  }
</style>
