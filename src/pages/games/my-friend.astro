---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GameCharacter from '@/components/games/GameCharacter.astro';
import OptionsBar from '@/games/my-friend/components/OptionsBar.astro';
import HitZones from '@/games/my-friend/components/HitZones.astro';
import config from '@/games/my-friend/config.json';
import type { MyFriendConfig } from '@/games/my-friend/types';

const cfg = config as MyFriendConfig;
---

<BaseLayout>
  <div
    x-data="myFriend"
    x-init="init()"
    class="relative h-full w-full overflow-hidden flex flex-col"
  >
    <div class="relative z-20 flex items-center justify-between px-4 py-3 w-full">
      <button
        @click="togglePause()"
        class="btn btn-ghost btn-sm btn-circle text-2xl"
        aria-label="Menu"
      >☰</button>
      <h1 class="text-lg text-purple-700">Meu Amigo</h1>
      <span class="w-8"></span>
    </div>

    <div
      class="flex-1 min-h-0 relative pointer-events-auto select-none"
      id="my-friend-stage"
    >
      <div class="floor"></div>
      <div class="character-stage">
        <div class="character-shadow"></div>
        <GameCharacter palette={cfg.defaultPalette} />
        <HitZones />
      </div>
      <div class="touch-fx" aria-hidden="true"></div>
    </div>

    <OptionsBar />

    <!-- Pause menu -->
    <div
      x-show="isPaused"
      x-transition
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-md"
    >
      <button
        @click="resumeGame()"
        class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/90 shadow-lg border-2 border-purple-200 flex items-center justify-center text-2xl text-purple-600"
        aria-label="Fechar"
      >✕</button>
      <div class="flex flex-col items-center gap-6">
        <button
          @click="resumeGame()"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-green-300 w-64"
        >
          <span class="text-4xl">▶️</span>
          <span class="text-xl text-green-600">Continuar</span>
        </button>
        <a
          href="/"
          class="flex items-center gap-4 bg-white/90 rounded-3xl px-8 py-5 shadow-xl border-2 border-red-300 w-64"
        >
          <span class="text-4xl">🚪</span>
          <span class="text-xl text-red-500">Sair do jogo</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import Alpine from 'alpinejs';
  import { createPresentation } from '@/games/my-friend/presentation';

  Alpine.data('myFriend', createPresentation);
  Alpine.start();
</script>

<style is:global>
  [x-cloak] { display: none !important; }

  #my-friend-stage {
    overflow: hidden;
  }

  #my-friend-stage .floor {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 50%;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(0,0,0,0.08) 0%, transparent 60%),
      linear-gradient(to bottom, #8FCB60 0%, #4F8A38 100%);
    border-top: 4px solid #B7E48A;
    z-index: 1;
    opacity: 0.5;
  }

  #my-friend-stage .character-stage {
    position: absolute;
    left: 50%;
    bottom: 25%;
    transform: translateX(-50%);
    width: clamp(440px, 95vw, 720px);
    line-height: 0;
    z-index: 3;
  }
  #my-friend-stage .character-stage > .character-container { display: block; width: 100%; }
  #my-friend-stage .character-stage svg.character-svg { width: 100%; height: auto; display: block; }

  #my-friend-stage .touch-fx {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 6;
  }
  #my-friend-stage .touch-ripple {
    position: absolute;
    width: 90px;
    height: 90px;
    margin-left: -45px;
    margin-top: -45px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(255, 220, 255, 0.55) 45%,
      rgba(180, 140, 255, 0.0) 80%
    );
    pointer-events: none;
    animation: my-friend-ripple 600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    will-change: transform, opacity;
  }
  @keyframes my-friend-ripple {
    0%   { transform: scale(0.2); opacity: 0.95; }
    60%  { opacity: 0.6; }
    100% { transform: scale(2.4); opacity: 0; }
  }

  /* ===== Activity layer ===== */
  #my-friend-stage .mf-activity-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 7;
  }

  /* ===== Eat (mesa de pratos + drag) ===== */
  #my-friend-stage .mf-eat-layer {
    pointer-events: none;
  }
  /* Durante o arrastar, desabilita as zonas de toque do personagem
     pra a criança não disparar reações sem querer. */
  #my-friend-stage.mf-eat-dragging svg.hit-zones {
    pointer-events: none;
  }
  #my-friend-stage .mf-eat-table {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(120px, 22vh, 180px);
    padding: 14px clamp(12px, 3vw, 28px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 2vw, 18px);
    flex-wrap: wrap;
    background: linear-gradient(to bottom, rgba(195, 130, 70, 0.95), rgba(140, 80, 30, 0.98));
    border-top: 5px solid #6B3410;
    box-shadow: 0 -6px 16px rgba(0, 0, 0, 0.25), inset 0 4px 0 rgba(255, 220, 180, 0.35);
    pointer-events: auto;
    touch-action: none;
    z-index: 8;
  }

  #my-friend-stage .mf-eat-plate {
    position: relative;
    width: clamp(56px, 12vw, 78px);
    height: clamp(56px, 12vw, 78px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    user-select: none;
    touch-action: none;
  }
  #my-friend-stage .mf-eat-plate:active { cursor: grabbing; }
  #my-friend-stage .mf-eat-dish {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 35%, #FFFFFF 0%, #E5E5E5 60%, #B8B8B8 100%);
    box-shadow:
      inset 0 -4px 6px rgba(0, 0, 0, 0.18),
      inset 0 4px 6px rgba(255, 255, 255, 0.9),
      0 6px 10px rgba(0, 0, 0, 0.25);
  }
  #my-friend-stage .mf-eat-food {
    position: relative;
    font-size: clamp(28px, 7vw, 42px);
    line-height: 1;
    pointer-events: none;
    filter: drop-shadow(0 3px 4px rgba(0, 0, 0, 0.25));
    transition: opacity 0.18s ease;
  }
  #my-friend-stage .mf-eat-drag {
    position: absolute;
    transform: translate(-50%, -50%) scale(1.2);
    font-size: clamp(36px, 9vw, 54px);
    z-index: 9;
    pointer-events: none;
    filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.32));
  }

  /* Partículas de "cresceu!" ao morder uma comida que aumenta a barriga */
  #my-friend-stage .mf-grow-spark {
    position: absolute;
    margin-left: -12px;
    margin-top: -12px;
    width: 24px;
    height: 24px;
    font-size: 22px;
    line-height: 24px;
    text-align: center;
    pointer-events: none;
    will-change: transform, opacity;
    animation: mf-grow-spark 900ms var(--delay, 0ms) cubic-bezier(0.22, 1, 0.36, 1) forwards;
    z-index: 9;
    text-shadow: 0 2px 6px rgba(255, 220, 110, 0.55);
  }
  @keyframes mf-grow-spark {
    0%   { transform: translate(0, 0)        rotate(0)             scale(0.3); opacity: 0; }
    20%  { transform: translate(calc(var(--dx, 0) * 0.25), calc(var(--dy, 0) * 0.25)) rotate(calc(var(--rot, 0) * 0.4)) scale(1.1); opacity: 1; }
    100% { transform: translate(var(--dx, 0), var(--dy, 0))         rotate(var(--rot, 0)) scale(0.7); opacity: 0; }
  }

  #my-friend-stage .mf-crumb {
    position: absolute;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    margin-top: -4px;
    border-radius: 50%;
    background: #C36B2D;
    animation: mf-crumb-fall 700ms ease-in forwards;
  }
  @keyframes mf-crumb-fall {
    0%   { transform: translate(0, 0) scale(1);   opacity: 1; }
    100% { transform: translate(var(--dx, 0), 80px) scale(0.6); opacity: 0; }
  }

  /* ===== Bath ===== */
  #my-friend-stage.mf-bath-dragging svg.hit-zones { pointer-events: none; }

  #my-friend-stage .mf-bathtub {
    position: absolute;
    left: 50%;
    bottom: 24%;
    width: clamp(360px, 75vw, 560px);
    transform: translate(-50%, 100%);
    animation: mf-bath-rise 600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    z-index: 4;
    will-change: transform;
  }
  #my-friend-stage .mf-bathtub svg { width: 100%; height: auto; display: block; }
  @keyframes mf-bath-rise {
    0%   { transform: translate(-50%, 100%); }
    100% { transform: translate(-50%, 18%); }
  }

  #my-friend-stage .mf-duck {
    position: absolute;
    width: clamp(40px, 7vw, 56px);
    transform: translate(-50%, -50%);
    transition: left 280ms ease-out, top 280ms ease-out;
    z-index: 5;
    animation: mf-duck-wobble 1800ms ease-in-out infinite;
    pointer-events: none;
  }
  #my-friend-stage .mf-duck.mf-duck-hidden {
    opacity: 0;
    visibility: hidden;
  }
  #my-friend-stage .mf-duck svg { width: 100%; height: auto; display: block; }
  @keyframes mf-duck-wobble {
    0%, 100% { transform: translate(-50%, -50%) rotate(-6deg); }
    50%      { transform: translate(-50%, calc(-50% - 6px)) rotate(6deg); }
  }

  /* Prateleira de itens do banho */
  #my-friend-stage .mf-bath-shelf {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(110px, 18vh, 150px);
    padding: 12px clamp(12px, 3vw, 28px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 2.5vw, 22px);
    flex-wrap: wrap;
    background: linear-gradient(to bottom, rgba(96, 165, 200, 0.95), rgba(48, 110, 150, 0.98));
    border-top: 5px solid #1F5C82;
    box-shadow: 0 -6px 16px rgba(0, 0, 0, 0.25), inset 0 4px 0 rgba(190, 230, 240, 0.4);
    pointer-events: auto;
    touch-action: none;
    z-index: 8;
  }
  #my-friend-stage .mf-bath-item {
    position: relative;
    width: clamp(56px, 12vw, 78px);
    height: clamp(56px, 12vw, 78px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    user-select: none;
    touch-action: none;
  }
  #my-friend-stage .mf-bath-item:active { cursor: grabbing; }
  #my-friend-stage .mf-bath-stand {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 35%, #FFFFFF 0%, #DFEAF1 60%, #A4BCCB 100%);
    box-shadow:
      inset 0 -4px 6px rgba(0, 0, 0, 0.18),
      inset 0 4px 6px rgba(255, 255, 255, 0.9),
      0 6px 10px rgba(0, 0, 0, 0.25);
  }
  #my-friend-stage .mf-bath-tool {
    position: relative;
    font-size: clamp(28px, 7vw, 42px);
    line-height: 1;
    pointer-events: none;
    filter: drop-shadow(0 3px 4px rgba(0, 0, 0, 0.25));
    transition: opacity 0.18s ease;
  }
  #my-friend-stage .mf-bath-drag {
    position: absolute;
    transform: translate(-50%, -50%) scale(1.2);
    font-size: clamp(36px, 9vw, 54px);
    z-index: 9;
    pointer-events: none;
    filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.32));
  }

  /* Espuma sobre a banheira */
  #my-friend-stage .mf-foam-wrap {
    position: absolute;
    left: 50%;
    bottom: calc(24% + clamp(360px, 75vw, 560px) * 0.10);
    width: clamp(320px, 70vw, 520px);
    height: clamp(60px, 12vw, 90px);
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 5;
  }
  #my-friend-stage .mf-foam-blob {
    position: absolute;
    width: clamp(50px, 14vw, 90px);
    height: clamp(40px, 10vw, 70px);
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, rgba(255,255,255,1) 0%, rgba(245,250,255,0.95) 55%, rgba(220,235,245,0.0) 90%);
    box-shadow: 0 0 8px rgba(255,255,255,0.6), inset 0 -6px 10px rgba(180,210,230,0.35);
    opacity: 0;
    transition: opacity 0.45s ease, transform 0.45s ease;
    will-change: opacity, transform;
  }
  #my-friend-stage .mf-foam-blob:nth-child(1) { left:  4%; bottom: 0;  transform: translateY(8px) scale(0.8); }
  #my-friend-stage .mf-foam-blob:nth-child(2) { left: 22%; bottom: 22%; transform: translateY(8px) scale(0.95); }
  #my-friend-stage .mf-foam-blob:nth-child(3) { left: 42%; bottom: 8%;  transform: translateY(8px) scale(1.1); }
  #my-friend-stage .mf-foam-blob:nth-child(4) { left: 60%; bottom: 28%; transform: translateY(8px) scale(0.9); }
  #my-friend-stage .mf-foam-blob:nth-child(5) { left: 78%; bottom: 4%;  transform: translateY(8px) scale(1); }
  #my-friend-stage .mf-foam-wrap[style*="--lvl: 1"] .mf-foam-blob:nth-child(-n+1),
  #my-friend-stage .mf-foam-wrap[style*="--lvl: 2"] .mf-foam-blob:nth-child(-n+2),
  #my-friend-stage .mf-foam-wrap[style*="--lvl: 3"] .mf-foam-blob:nth-child(-n+3),
  #my-friend-stage .mf-foam-wrap[style*="--lvl: 4"] .mf-foam-blob:nth-child(-n+4),
  #my-friend-stage .mf-foam-wrap[style*="--lvl: 5"] .mf-foam-blob:nth-child(-n+5) {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* Espuma na cabeça (chapéu de bolha quando shampoo aplicado) */
  #my-friend-stage .mf-foam-hat {
    position: absolute;
    width: 100px;
    height: 70px;
    transform: translate(-50%, -100%) scale(0.6);
    opacity: 0;
    background:
      radial-gradient(circle at 30% 60%, rgba(255,255,255,1) 0 22px, transparent 24px),
      radial-gradient(circle at 50% 30%, rgba(255,255,255,1) 0 28px, transparent 30px),
      radial-gradient(circle at 70% 60%, rgba(255,255,255,1) 0 22px, transparent 24px),
      radial-gradient(circle at 50% 75%, rgba(255,255,255,1) 0 26px, transparent 28px);
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
    z-index: 6;
  }
  #my-friend-stage .mf-foam-hat.is-on {
    opacity: 1;
    transform: translate(-50%, -100%) scale(1);
  }

  /* Bolhas de sabonete (efeito local no drop) */
  #my-friend-stage .mf-bubble-soap {
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,1), rgba(240,250,255,0.85) 60%, rgba(220,240,250,0) 100%);
    box-shadow: inset 0 0 6px rgba(255,255,255,0.85);
  }

  /* Gotas do chuveiro */
  #my-friend-stage .mf-rain-drop {
    position: absolute;
    width: 6px;
    height: 14px;
    margin-left: -3px;
    border-radius: 60% 60% 50% 50% / 50% 50% 80% 80%;
    background: linear-gradient(to bottom, rgba(170,220,250,0.95), rgba(80,160,220,0.95));
    pointer-events: none;
    will-change: transform, opacity;
    animation: mf-rain-fall 540ms var(--delay, 0ms) ease-in forwards;
    z-index: 7;
  }
  @keyframes mf-rain-fall {
    0%   { transform: translate(0, 0)            scale(0.7); opacity: 0; }
    20%  { opacity: 1; }
    100% { transform: translate(0, var(--dy, 100px)) scale(0.9); opacity: 0; }
  }

  /* Splash do patinho */
  #my-friend-stage .mf-splash-drop {
    position: absolute;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    margin-top: -4px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(220,245,255,1), rgba(120,180,210,0.9));
    pointer-events: none;
    will-change: transform, opacity;
    animation: mf-splash-out 520ms ease-out forwards;
    z-index: 7;
  }
  @keyframes mf-splash-out {
    0%   { transform: translate(0, 0) scale(0.6); opacity: 1; }
    100% { transform: translate(var(--dx, 0), var(--dy, -30px)) scale(1.1); opacity: 0; }
  }

  #my-friend-stage .mf-bubble {
    position: absolute;
    margin-left: -50%;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.95), rgba(180,220,240,0.5) 60%, rgba(160,200,230,0) 100%);
    box-shadow: inset 0 0 6px rgba(255,255,255,0.6);
    pointer-events: none;
    will-change: transform, opacity;
    animation: mf-bubble-rise var(--dur, 1800ms) ease-out forwards;
    z-index: 6;
  }
  @keyframes mf-bubble-rise {
    0%   { transform: translate(0, 0)                       scale(0.4); opacity: 0; }
    20%  { transform: translate(calc(var(--dx, 0) * 0.2), -30px) scale(0.85); opacity: 0.95; }
    100% { transform: translate(var(--dx, 0), -240px)        scale(1.05); opacity: 0; }
  }

  /* ===== Gift ===== */
  #my-friend-stage .mf-gift-box {
    position: absolute;
    left: 50%;
    bottom: 22%;
    width: clamp(110px, 18vw, 150px);
    transform: translate(-50%, -200%);
    animation: mf-gift-drop 600ms cubic-bezier(0.5, 0, 0.75, 1) forwards,
               mf-gift-shake 200ms 700ms ease-in-out 3 alternate;
    z-index: 5;
    will-change: transform;
  }
  #my-friend-stage .mf-gift-box svg { width: 100%; height: auto; display: block; }
  @keyframes mf-gift-drop {
    0%   { transform: translate(-50%, -260%); }
    80%  { transform: translate(-50%, 6%); }
    100% { transform: translate(-50%, 0); }
  }
  @keyframes mf-gift-shake {
    0%   { transform: translate(-50%, 0)  rotate(-4deg); }
    100% { transform: translate(-50%, 0)  rotate(4deg); }
  }

  #my-friend-stage .mf-gift-lid {
    position: absolute;
    left: 50%;
    bottom: calc(22% + clamp(110px, 18vw, 150px) * 0.62);
    width: clamp(120px, 20vw, 165px);
    transform: translate(-50%, 0) scale(1);
    opacity: 0;
    animation: mf-gift-lid-fly 1200ms 1600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    z-index: 6;
    will-change: transform, opacity;
  }
  #my-friend-stage .mf-gift-lid svg { width: 100%; height: auto; display: block; }
  @keyframes mf-gift-lid-fly {
    0%   { transform: translate(-50%, 0)     rotate(0)    scale(1);   opacity: 1; }
    25%  { transform: translate(-50%, -120px) rotate(-12deg) scale(1.05); opacity: 1; }
    100% { transform: translate(-50%, -260px) rotate(35deg)  scale(0.9);  opacity: 0; }
  }

  .mf-gift-confetti {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
  }

  /* ===== Sleep ===== */
  /* Remove o personagem ao vivo (e tudo dentro dele) + hit-zones do layout
     durante a cena de dormir, pra evitar resquícios de blush/olho/boca
     sobre o personagem deitado de lado. */
  #my-friend-stage.mf-sleep-active .character-stage {
    display: none !important;
  }
  #my-friend-stage.mf-sleep-active .hit-zones,
  #my-friend-stage.mf-sleep-active svg.hit-zones {
    display: none !important;
    pointer-events: none !important;
  }

  #my-friend-stage .mf-side-char {
    position: absolute;
    left: calc(50% - 15px);
    bottom: calc(18% - 30px);
    width: clamp(360px, 78vw, 580px);
    transform: translate(-50%, -8%);
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    animation: mf-side-char-in 600ms 200ms ease-out forwards;
    filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.18));
  }
  #my-friend-stage .mf-side-char svg { width: 100%; height: auto; display: block; }
  @keyframes mf-side-char-in {
    0%   { opacity: 0; transform: translate(-50%, 6%); }
    100% { opacity: 1; transform: translate(-50%, -8%); }
  }

  #my-friend-stage .mf-bed {
    position: absolute;
    left: 50%;
    bottom: 18%;
    width: clamp(360px, 78vw, 580px);
    transform: translate(-50%, 60%);
    opacity: 0;
    animation: mf-bed-rise 600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    pointer-events: none;
    z-index: 2;
    will-change: transform, opacity;
    filter: drop-shadow(0 8px 14px rgba(0, 0, 0, 0.28));
  }
  #my-friend-stage .mf-bed svg { width: 100%; height: auto; display: block; }
  @keyframes mf-bed-rise {
    0%   { opacity: 0; transform: translate(-50%, 60%); }
    100% { opacity: 1; transform: translate(-50%, 0); }
  }

  #my-friend-stage .mf-sleep-dim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at 50% 35%, rgba(20, 14, 60, 0) 0%, rgba(20, 14, 60, 0.55) 80%);
    opacity: 0;
    animation: mf-dim-in 800ms ease-out forwards;
    z-index: 4;
  }
  @keyframes mf-dim-in {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  #my-friend-stage .mf-zzz {
    position: absolute;
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 800;
    color: #C7B8E5;
    text-shadow: 0 2px 6px rgba(40, 20, 80, 0.45);
    pointer-events: none;
    will-change: transform, opacity;
    animation: mf-zzz-rise var(--dur, 2400ms) ease-out forwards;
    z-index: 6;
  }
  @keyframes mf-zzz-rise {
    0%   { transform: translate(-50%, 0)        rotate(-10deg) scale(0.4); opacity: 0; }
