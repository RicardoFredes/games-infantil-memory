---
const zones = [
  { id: 'arm-l',  x: -90, y:  80, w: 130, h:  80 },
  { id: 'arm-r',  x: 220, y:  80, w: 130, h:  80 },
  { id: 'leg-l',  x:  75, y: 195, w:  40, h:  50 },
  { id: 'leg-r',  x: 145, y: 195, w:  40, h:  50 },
  { id: 'foot-l', x:  40, y: 235, w:  80, h:  50 },
  { id: 'foot-r', x: 140, y: 235, w:  80, h:  50 },
  { id: 'body',   x:  30, y: 160, w: 200, h:  85 },
  { id: 'head',   x:  30, y:   0, w: 200, h: 100 },
  { id: 'mouth',  x:  90, y: 125, w:  80, h:  40 },
  { id: 'eye-l',  x:  74, y:  75, w:  50, h:  45 },
  { id: 'eye-r',  x: 135, y:  75, w:  55, h:  45 },
];
---

<svg
  class="hit-zones"
  viewBox="-90 -110 440 400"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {
    zones.map((z) => (
      <rect
        x={z.x}
        y={z.y}
        width={z.w}
        height={z.h}
        fill="transparent"
        data-zone={z.id}
      />
    ))
  }
</svg>

<style>
  .hit-zones {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: auto;
    touch-action: none;
    z-index: 5;
  }
  .hit-zones rect { cursor: pointer; }
</style>
