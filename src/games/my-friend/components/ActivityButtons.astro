---
const activities = [
  { id: 'eat',   emoji: '🍎', label: 'Comer',    color: '#FF7A7A' },
  { id: 'bath',  emoji: '🛁', label: 'Banho',    color: '#7FB8E8' },
  { id: 'sleep', emoji: '😴', label: 'Dormir',   color: '#C7B8E5' },
  { id: 'gift',  emoji: '🎁', label: 'Presente', color: '#FFD86B' },
];
---

<div class="activity-buttons flex items-center justify-center gap-2 px-3 pt-2 pb-1 flex-wrap">
  {
    activities.map((a) => (
      <button
        type="button"
        class="activity-btn"
        :class={`activeActivity === '${a.id}' ? 'is-active' : ''`}
        @click={`pickActivity('${a.id}')`}
        aria-label={a.label}
        style={`--activity-color: ${a.color};`}
      >
        <span class="activity-emoji" aria-hidden="true">{a.emoji}</span>
      </button>
    ))
  }
</div>

<style>
  .activity-btn {
    width: clamp(44px, 12vw, 60px);
    height: clamp(44px, 12vw, 60px);
    border-radius: 9999px;
    background: var(--activity-color, #fff);
    border: 4px solid white;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.18);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    outline: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .activity-btn:active { transform: scale(0.92); }
  .activity-btn:hover  { transform: scale(1.05); }
  .activity-btn.is-active {
    transform: scale(1.15);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.45), 0 6px 14px rgba(0, 0, 0, 0.22);
  }
  .activity-emoji {
    font-size: clamp(22px, 6vw, 30px);
    line-height: 1;
    pointer-events: none;
  }
</style>
