---
interface Props {
  showReset?: boolean;
  homeHref?: string;
}

const { showReset = false, homeHref = '/' } = Astro.props;
---

<div
  x-show="isPaused"
  x-cloak
  x-transition:enter="transition duration-300 ease-out"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition duration-200 ease-in"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-50 flex flex-col items-center justify-center gap-10 bg-black/45 backdrop-blur-md"
  @click.self="resumeGame()"
  @keydown.escape.window="isPaused && resumeGame()"
  x-data={`{
    holdTimer: null,
    holdRaf: null,
    holdProgress: 0,
    HOLD_MS: 850,
    homeHref: ${JSON.stringify(homeHref)},
    startHold(e) {
      if (e && e.cancelable && typeof e.preventDefault === 'function') e.preventDefault();
      if (this.holdTimer || this.holdRaf) this.cancelHold();
      const href = this.homeHref;
      const ms = this.HOLD_MS;
      const startedAt = performance.now();
      this.holdTimer = window.setTimeout(() => {
        this.holdProgress = 1;
        this.holdTimer = null;
        window.location.href = href;
      }, ms);
      const tick = () => {
        if (this.holdTimer === null) { this.holdRaf = null; return; }
        const elapsed = performance.now() - startedAt;
        this.holdProgress = Math.min(1, elapsed / ms);
        if (this.holdProgress < 1) this.holdRaf = requestAnimationFrame(tick);
        else this.holdRaf = null;
      };
      this.holdRaf = requestAnimationFrame(tick);
    },
    cancelHold() {
      if (this.holdTimer) { clearTimeout(this.holdTimer); this.holdTimer = null; }
      if (this.holdRaf) { cancelAnimationFrame(this.holdRaf); this.holdRaf = null; }
      this.holdProgress = 0;
    }
  }`}
>
  <!-- Linha principal: continuar + sair -->
  <div
    x-transition:enter="transition duration-400 ease-out delay-75"
    x-transition:enter-start="opacity-0 scale-90 translate-y-4"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
    class="flex items-center justify-center gap-6 sm:gap-10 px-4"
  >
    <!-- Continuar -->
    <button
      type="button"
      @click="resumeGame()"
      class="kids-menu-btn kids-menu-btn--play"
      aria-label="Continuar"
    >
      <span class="kids-menu-pulse-ring" aria-hidden="true"></span>
      <svg class="kids-menu-icon kids-menu-icon--play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5.5c0-.83.93-1.32 1.62-.86l9 6.5c.6.43.6 1.29 0 1.72l-9 6.5c-.69.46-1.62-.03-1.62-.86v-13z" />
      </svg>
    </button>

    <!-- Sair (segurar para confirmar) -->
    <button
      type="button"
      class="kids-menu-btn kids-menu-btn--home"
      aria-label="Voltar para o início (segure)"
      @pointerdown="startHold($event)"
      @pointerup="cancelHold()"
      @pointerleave="cancelHold()"
      @pointercancel="cancelHold()"
      @touchstart.prevent="startHold($event)"
      @touchend="cancelHold()"
      @touchcancel="cancelHold()"
      @mousedown="startHold($event)"
      @mouseup="cancelHold()"
      @mouseleave="cancelHold()"
      @contextmenu.prevent="cancelHold()"
      :class="holdProgress > 0 ? 'is-holding' : ''"
    >
      <svg class="kids-menu-ring" viewBox="0 0 100 100" aria-hidden="true">
        <circle class="kids-menu-ring-track" cx="50" cy="50" r="46" pathLength="1" />
        <circle
          class="kids-menu-ring-fill"
          cx="50" cy="50" r="46" pathLength="1"
          :style="`stroke-dashoffset: ${1 - holdProgress};`"
        />
      </svg>
      <svg class="kids-menu-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 3.05 2.6 11.18a1 1 0 0 0-.35.76V20a1.5 1.5 0 0 0 1.5 1.5h4.6a.75.75 0 0 0 .75-.75V16a1.5 1.5 0 0 1 1.5-1.5h2.8a1.5 1.5 0 0 1 1.5 1.5v4.75c0 .41.34.75.75.75h4.6A1.5 1.5 0 0 0 21.75 20v-8.06a1 1 0 0 0-.35-.76L12 3.05z" />
      </svg>
    </button>
  </div>

  {showReset && (
    <button
      type="button"
      @click="resetHistory()"
      class="kids-menu-reset"
      x-transition:enter="transition duration-400 ease-out delay-150"
      x-transition:enter-start="opacity-0 translate-y-3"
      x-transition:enter-end="opacity-100 translate-y-0"
    >
      <svg class="kids-menu-reset-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 12a8 8 0 1 1-2.34-5.66" />
        <polyline points="20 4 20 9 15 9" />
      </svg>
      <span>Apagar dados</span>
    </button>
  )}
</div>

<style is:global>
  .kids-menu-btn {
    position: relative;
    width: clamp(120px, 26vw, 156px);
    height: clamp(120px, 26vw, 156px);
    border-radius: 9999px;
    border: 5px solid #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.28), inset 0 -8px 0 rgba(0, 0, 0, 0.1);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    cursor: pointer;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: none;
    user-select: none;
  }
  .kids-menu-btn:active {
    transform: translateY(2px) scale(0.96);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.22), inset 0 -4px 0 rgba(0, 0, 0, 0.1);
  }
  .kids-menu-btn:focus-visible {
    box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.7), 0 14px 30px rgba(0, 0, 0, 0.28);
  }

  .kids-menu-icon {
    width: 54%;
    height: 54%;
    display: block;
    filter: drop-shadow(0 2px 0 rgba(0, 0, 0, 0.15));
    pointer-events: none;
  }
  .kids-menu-icon--play { transform: translateX(4%); }

  .kids-menu-btn--play {
    background: linear-gradient(180deg, #34d399 0%, #059669 100%);
  }
  .kids-menu-btn--home {
    background: linear-gradient(180deg, #fb7185 0%, #e11d48 100%);
  }

  .kids-menu-pulse-ring {
    position: absolute;
    inset: -6px;
    border-radius: 9999px;
    border: 4px solid rgba(52, 211, 153, 0.55);
    pointer-events: none;
    animation: kids-menu-pulse 1.6s ease-out infinite;
  }
  @keyframes kids-menu-pulse {
    0%   { transform: scale(0.94); opacity: 0.85; }
    80%  { transform: scale(1.18); opacity: 0; }
    100% { transform: scale(1.18); opacity: 0; }
  }

  .kids-menu-ring {
    position: absolute;
    inset: -10px;
    width: calc(100% + 20px);
    height: calc(100% + 20px);
    pointer-events: none;
    transform: rotate(-90deg);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .kids-menu-btn--home.is-holding .kids-menu-ring { opacity: 1; }
  .kids-menu-btn--home.is-holding {
    transform: scale(1.06);
  }
  .kids-menu-ring-track {
    fill: none;
    stroke: rgba(255, 255, 255, 0.35);
    stroke-width: 7;
  }
  .kids-menu-ring-fill {
    fill: none;
    stroke: #ffffff;
    stroke-width: 7;
    stroke-linecap: round;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 60ms linear;
  }

  .kids-menu-reset {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.25rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.92);
    color: #b45309;
    border: 2px solid rgba(217, 119, 6, 0.45);
    font-weight: 800;
    font-size: 0.95rem;
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .kids-menu-reset:active {
    transform: translateY(1px) scale(0.97);
  }
  .kids-menu-reset-icon {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }
</style>
