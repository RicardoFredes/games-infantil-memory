<div
  x-data="{ show: false, text: '' }"
  x-show="show"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 scale-50"
  x-transition:enter-end="opacity-100 scale-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 scale-100"
  x-transition:leave-end="opacity-0 scale-50"
  @memory-sequence:state-change.window="show = $event.detail.gameState === 'CELEBRATING'"
  @celebration.window="text = $event.detail.text; show = true; setTimeout(() => show = false, 2000)"
  class="fixed inset-0 z-40 flex items-center justify-center pointer-events-none"
>
  <div class="bg-white/90 backdrop-blur-xl rounded-3xl px-8 py-6 shadow-2xl border-4 border-yellow-300">
    <p class="text-3xl font-black text-purple-700 text-center animate-bounce" x-text="text"></p>
  </div>
</div>
