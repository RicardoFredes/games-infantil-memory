---
export interface Props {
  index: number;
  color: string;
  glow: string;
  emoji: string;
  label: string;
}

const { index, color, glow, emoji, label } = Astro.props;
const idx = String(index);
const activeBg = `background: ${glow}; box-shadow: 0 0 60px ${glow}, 0 0 100px ${glow}`;
const idleBg = `background: ${color}`;
const styleExpression = `active ? '${activeBg}' : '${idleBg}'`;
const onLightOn = `$event.detail.index === ${idx} && (active = true)`;
const onLightOff = `$event.detail.index === ${idx} && (active = false)`;
const onPointerDown = `active = true; $dispatch('ml:light-tap', { index: ${idx} })`;
---

<button
  x-data="{ active: false, flashColor: '', flashShow: false }"
  @ml:light-on.window={onLightOn}
  @ml:light-off.window={onLightOff}
  @pointerdown={onPointerDown}
  @pointerup="active = false"
  @pointerleave="active = false"
  @ml:all-lights-flash.window="flashColor = $event.detail.color; flashShow = true; setTimeout(() => flashShow = false, $event.detail.duration)"
  class="relative w-[min(25vmin,140px)] h-[min(25vmin,140px)] min-w-[80px] min-h-[80px]
    rounded-full flex items-center justify-center
    transition-all duration-200 ease-out
    border-[5px] border-white/70 shadow-xl
    cursor-pointer select-none z-10
    hover:scale-105"
  :class="active ? 'scale-110 brightness-125 ring-[6px] ring-white/50' : 'scale-100'"
  :style={styleExpression}
  :aria-pressed="active ? 'true' : 'false'"
  aria-label={label}
>
  <!-- Error/success flash overlay -->
  <div
    x-show="flashShow"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-80"
    x-transition:enter-end="opacity-0"
    class="absolute inset-0 rounded-full pointer-events-none"
    :style="'background: ' + flashColor"
  ></div>
  <!-- Ripple effect -->
  <div
    x-show="active"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-50 scale-0"
    x-transition:enter-end="opacity-0 scale-[2.5]"
    class="absolute inset-0 rounded-full bg-white/40 pointer-events-none"
  ></div>
  <span class="text-4xl md:text-5xl pointer-events-none drop-shadow-lg select-none z-10" aria-hidden="true">
    {emoji}
  </span>
</button>
